{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // "outDir": "dist/libs/editor/types",
    // "declaration": true,
    // "emitDeclarationOnly": true,
    // "skipLibCheck": true,
    // "strict": false,
    //"outDir": "dist/libs/editor/types",
    "declaration": true,
    //"emitDeclarationOnly": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,
    "allowUnreachableCode": true,
    "allowUnusedLabels": true,
    "allowJs": true,
  },
    "files": [
  ],
  "include": ["src/**/*", "src/**/*", "node_modules/@types"],
    "references": [
    { "path": "../ui" }
  ],
  "exclude": [
    "jest.config.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx"
  ]
}